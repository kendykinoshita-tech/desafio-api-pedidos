                      "",
                      "    // Verifica se o token existe no corpo da resposta antes de salvar",
                      "    if (jsonResponse.data.accessToken) {",
                      "        pm.environment.set(\"accessToken\", jsonResponse.data.accessToken);",
                      "    } else {",
                      "        console.log(\"accessToken não encontrado na resposta.\");",
                      "    }",
                      "} else {",
